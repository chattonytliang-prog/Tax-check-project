{
  "name": "tax-risk-mvp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "preview": "vite preview",
    "d1:list": "wrangler d1 list",
    "d1:migrate:assistant": "wrangler d1 execute tax-check-db --remote --file=migrations/0007_assistant_business_tools.sql",
    "d1:migrate:intake": "wrangler d1 execute tax-check-db --remote --file=migrations/0008_full_tax_data_intake.sql"
  },
  "dependencies": {
    "@e965/xlsx": "^0.20.3",
    "echarts": "^6.1.0",
    "lucide-react": "^1.21.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@emnapi/core": "^1.11.2",
    "@emnapi/runtime": "^1.11.2",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.9",
    "wrangler": "^4.109.0"
  }
}
